{
  "manifest_version": 3,
  "name": "Claude Themes",
  "version": "1.1.0",
  "description": "Reskin claude.ai with 6 retro palettes. Assign a color to each project — tab-glance your way between them.",
  "host_permissions": ["https://claude.ai/*"],
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "css": [
        "content.css",
        "variants/amber.css",
        "variants/green.css",
        "variants/white.css",
        "variants/cga.css",
        "variants/crt.css",
        "variants/synthwave.css"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Claude Themes",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-themes@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
